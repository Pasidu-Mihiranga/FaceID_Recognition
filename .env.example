# FaceID Configuration Settings

# --- Web Interface ---
FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=1

# --- Face Recognition Thresholds ---
# How strict the matching should be (0.0 to 1.0)
RECOGNITION_THRESHOLD=0.7

# --- Continuous Learning ---
# How high the confidence must be to automatically learn a new face angle
LEARNING_THRESHOLD=0.85

# --- Database ---
DB_PATH=data/database.sqlite
EMBEDDINGS_DIR=data/embeddings

# --- Camera ---
CAMERA_INDEX=0

# --- ML Advanced ---
LIVENESS_THRESHOLD=0.8
MIN_FACE_QUALITY=0.6
